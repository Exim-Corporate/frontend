{
  // https://nuxt.com/docs/guide/concepts/typescript
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig.tsbuildinfo"
  },
  "include": [
    "components/**/*.vue",
    "composables/**/*.ts",
    "layouts/**/*.vue",
    "pages/**/*.vue",
    "plugins/**/*.ts",
    "server/**/*.ts",
    "utils/**/*.ts",
    "types/**/*.d.ts",
    "app.vue",
    "error.vue",
    "nuxt.config.ts",
    "app/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", ".output", "changes"]
}
